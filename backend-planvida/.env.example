# =========================================================
# PlanVida Backend - Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# =========================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000

# CORS: domínios permitidos a chamar a API (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://vmmanutencaoindustrial-create.github.io

# URL pública do FRONTEND (usada nos redirects do Mercado Pago)
FRONTEND_URL=https://vmmanutencaoindustrial-create.github.io/planvida-renascer

# URL pública do BACKEND (usada pelo webhook do Mercado Pago)
# Após deploy no Render, troque para https://seu-app.onrender.com
BACKEND_URL=http://localhost:3000

# --- Banco de dados PostgreSQL ---
# Local (docker / instalação local):
# DATABASE_URL="postgresql://user:password@localhost:5432/planvida?schema=public"
#
# Render Postgres (formato oficial):
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/DATABASE?schema=public"

# --- JWT (gerar string aleatória com: openssl rand -base64 48) ---
JWT_SECRET=troque_isso_por_uma_string_aleatoria_longa_de_pelo_menos_48_caracteres_random
JWT_EXPIRES_IN=7d

# --- Painel Administrativo ---
# Usado pra logar em /admin.html (única conta com acesso ao painel admin)
ADMIN_EMAIL=admin@planvida.com
ADMIN_PASSWORD=troque_isso_por_uma_senha_forte_de_pelo_menos_12_caracteres

# --- Mercado Pago ---
# Pegar em: https://www.mercadopago.com.br/developers/panel/app
# Para teste use Sandbox (TEST-...). Em produção use as credenciais reais (APP_USR-...).
MP_ACCESS_TOKEN=TEST-1234567890-abcdef-COLOQUE-O-SEU-AQUI
MP_PUBLIC_KEY=TEST-abcdef-1234567890-PUBLIC-KEY
MP_WEBHOOK_SECRET=segredo_para_validar_webhooks_opcional
